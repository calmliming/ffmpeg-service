#端口号
PORT=9527
#在本地开发且 ffmpeg 不在系统 PATH 中时（比如 macOS 用 brew 装到了非标准路径），才需要显式配置路径。
FFMPEG_PATH=/usr/bin/ffmpeg
# 是否在本地保存输出的 mp4 文件（false 时文件下载后自动清理）
SAVE_OUTPUT_FILE=true
# 最大并发任务数（2G2核服务器建议 3，默认 max(1, CPU核数-1)）
MAX_CONCURRENT_TASKS=3
# Redis 连接地址（本地开发用 localhost，Docker 部署用 redis://redis:6379）
REDIS_URL=redis://localhost:6379
# API_URL=http://124.221.157.202:9527
API_URL=http://47.251.20.9:9527
